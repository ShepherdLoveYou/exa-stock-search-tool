# Exa API Key
# Get your API key from: https://dashboard.exa.ai/api-keys
EXA_API_KEY=your_api_key_here

# Optional: OpenAI API Key (for function calling examples)
OPENAI_API_KEY=your_openai_key_here

# Optional: Anthropic API Key (for tool use examples)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Configuration
SEARCH_TYPE=auto
NUM_RESULTS=10
MAX_CHARACTERS=4000
